# このファイルをコピーして `app/.env` を作成してください。
# app ディレクトリで:
#   cp .env.example .env
# Flutter の URL（ポート）は変わってよい。API だけポート固定なら .env.example を触らなくてよい。
# api は ./start.sh で常に http://127.0.0.1:8000
#
# OpenAI のキーはここには書かない（`api/` 側の環境変数のみ）。

# 必須: 自前 API（末尾スラッシュなし）
# ローカル（api/start.sh の既定ポート。変えないならこのままコミット例でも固定でよい）
CORRECTION_API_BASE_URL=http://127.0.0.1:8000
# 本番では Vercel の URL に差し替え:
# CORRECTION_API_BASE_URL=https://english-training-api.vercel.app

# Supabase（Project Settings → API）。教材・履歴はログイン後のみ RLS で読める。
# 本番: Authentication → メール確認をオフ（メール+パスワードのみ・即ログイン）
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key
