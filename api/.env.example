OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# 発話評価だけ別モデルにしたいとき（未設定なら OPENAI_MODEL）。速さ重視なら gpt-4o-mini 推奨。
# OPENAI_EVAL_SPEECH_MODEL=gpt-4o-mini
# OPENAI_API_BASE=https://api.openai.com/v1

# 任意: API の待受（既定: 127.0.0.1:8000 で固定）
# API_HOST=127.0.0.1
# API_PORT=8000

# 任意: CORS。未設定時は start.sh が ALLOWED_ORIGINS=*（ローカル用）を付与。
# 本番では必ずフロントのオリジンを列挙すること。
# ALLOWED_ORIGINS=https://your-frontend.example.com

# 任意: POST /v1/speech/transcribe（OpenAI Whisper）のモデル（既定 whisper-1）。OPENAI_API_KEY と同じプロジェクトで課金。
# OPENAI_WHISPER_MODEL=whisper-1
